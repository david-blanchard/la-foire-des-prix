{% extends 'layouts/auth.html.twig' %}

{% block title %}Register{% endblock %}

{% block children %}
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">{{ 'Register'|trans }}</div>

                    <div class="card-body">
                        {{ form_start(registrationForm) }}

                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

                        <div class="form-group row">
                            <div class="col-md-6">
                                {{ form_errors(registrationForm) }}
                            </div>
                        </div>

                        <div class="form-group row">
                            {{ form_label(registrationForm.email, 'Email address', {'label_attr': {'class': 'col-md-4 col-form-label text-md-right'}}) }}
                            <div class="col-md-6">
                                {{ form_widget(registrationForm.email, {
                                    'attr': {
                                        'class': 'form-control',
                                        'placeholder': 'you@example.com'
                                    }
                                }) }}
                                {% if errors.email is defined %}
                                    <span class="invalid-feedback" role="alert">
                                    <strong>{{ errors.email }}</strong>
                                </span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="form-group row">
                            {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'col-md-4 col-form-label text-md-right'}}) }}
                            <div class="col-md-6">
                                {{ form_widget(registrationForm.plainPassword, {
                                    'attr': {
                                        'class': 'form-control',
                                        'placeholder': '********'
                                    }
                                }) }}
                                {% if errors.password is defined %}
                                    <span class="invalid-feedback" role="alert">
                                    <strong>{{ errors.password }}</strong>
                                </span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="form-group row">
                            {{ form_label(registrationForm.agreeTerms, 'Agree terms', {'label_attr': {'class': 'col-md-4 col-form-label text-md-right'}}) }}
                            <div class="col-md-6">
                                {{ form_widget(registrationForm.agreeTerms, {
                                    'attr': {
                                        'class': 'text-md-right',
                                    }
                                }) }}
                            </div>
                        </div>

                        <div class="form-group row mb-0">
                            <div class="col-md-6 offset-md-4">
                                <button type="submit" class="btn btn-outline-primary">
                                    {{ 'Register'|trans }}
                                </button>
                            </div>
                        </div>
                        {{ form_end(registrationForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
