                srcset="{{ asset(logo) }}" media="(min-width: 1200px)"
                />
                <img id="logo" src='{{ asset(logo) }}' alt='Les Prix Bas' />
            </picture>
        </a>

        <div id="subnavbar0" class='navbar-collapse offcanvas-collapse'>
