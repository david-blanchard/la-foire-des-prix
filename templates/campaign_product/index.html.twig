<!DOCTYPE html>

<title>CampaignProduct index</title>

{% block body %}
    <h1>CampaignProduct index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for campaign_product in campaign_products %}
            <tr>
                <td>{{ campaign_product.id }}</td>
                <td>
                    <a href="{{ path('app_campaign_product_show', {'id': campaign_product.id}) }}">show</a>
                    <a href="{{ path('app_campaign_product_edit', {'id': campaign_product.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="2">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_campaign_product_new') }}">Create new</a>
{% endblock %}
