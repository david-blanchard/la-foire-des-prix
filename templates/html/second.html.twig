<!-- Fil d’Ariane -->
<div class="border-b bg-gray-50">
    <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-3 text-sm text-gray-600">
        <ol class="flex flex-wrap items-center gap-2">
            <li><a href="/" class="hover:text-gray-900">Accueil</a></li>
            <li class="text-gray-400">/</li>
            <li><a href="#" class="hover:text-gray-900">Mode femme</a></li>
            <li class="text-gray-400">/</li>
            <li><a href="#" class="hover:text-gray-900">Robe courte éponge Jodie</a></li>
            <li class="text-gray-400">/</li>
            <li class="text-gray-900 font-medium">Réédition</li>
        </ol>
