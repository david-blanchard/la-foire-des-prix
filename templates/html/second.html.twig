            </div>
            <div>
                <h3 class="text-sm font-semibold">Resources</h3>
                <ul class="mt-3 space-y-2 text-sm text-gray-600">
                    <li><a href="#" class="hover:text-gray-900">Resource</a></li>
                    <li><a href="#" class="hover:text-gray-900">Resource name</a></li>
                    <li><a href="#" class="hover:text-gray-900">Another resource</a></li>
                    <li><a href="#" class="hover:text-gray-900">Final resource</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-sm font-semibold">About</h3>
                <ul class="mt-3 space-y-2 text-sm text-gray-600">
                    <li><a href="#" class="hover:text-gray-900">Team</a></li>
                    <li><a href="#" class="hover:text-gray-900">Locations</a></li>
                    <li><a href="#" class="hover:text-gray-900">Privacy</a></li>
                    <li><a href="#" class="hover:text-gray-900">Terms</a></li>
                </ul>
            </div>
            <div class="text-sm text-gray-600">
                <p class="font-semibold">© 2021</p>
            </div>
        </div>
    </div>
</footer>

<!-- JS minimal pour quantité -->
<script>
    const root = document.currentScript.closest("body");
    root.querySelector("[data-inc]")?.addEventListener("click", () => {
        const input = document.getElementById("qty");
        input.value = Math.max(1, (parseInt(input.value || "1", 10) + 1));
    });
    root.querySelector("[data-dec]")?.addEventListener("click", () => {
        const input = document.getElementById("qty");
        input.value = Math.max(1, (parseInt(input.value || "1", 10) - 1));
    });
</script>
</body>
</html>
