<!DOCTYPE html>

<title>Campaign</title>

{% block body %}
    <h1>Campaign</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ campaign.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ campaign.name }}</td>
            </tr>
            <tr>
                <th>Start</th>
                <td>{{ campaign.start ? campaign.start|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>End</th>
                <td>{{ campaign.end ? campaign.end|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Discount</th>
                <td>{{ campaign.discount }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_campaign_index') }}">back to list</a>

    <a href="{{ path('app_campaign_edit', {'id': campaign.id}) }}">edit</a>

    {{ include('campaign/_delete_form.html.twig') }}
{% endblock %}
