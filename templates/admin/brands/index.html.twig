{% extends 'layouts/admin.html.twig' %}

{% block children %}
<div class="container">
    <h2 class="text-center my-5">
        Marques
        <a href="{{ path('admin_brands_create') }}" class="btn btn-outline-primary" alt="Créer" title="Créer">
            <i class="bi bi-pencil" aria-hidden="true"></i>
        </a>
    </h2>
    <table class="table table-striped table-sm">
        <thead class="thead-dark">
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Libellé</th>
                <th scope="col">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for brand in brands %}
            <tr>
                <th>{{ brand.id }}</th>
                <td>{{ brand.name }}</td>
                <td>
                    <a href="{{ path('admin_brands_edit', { id: brand.id }) }}" class="btn btn-outline-warning" alt="Editer {{ brand.id }}" title="Editer {{ brand.id }}">
                        <i class="bi bi-pencil" aria-hidden="true"></i>
                    </a>

                    <button type="button" class="btn btn-outline-danger" onclick="document.querySelector('#delete-modal-{{ brand.id }}').style.display='block'">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </button>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
<div class="d-flex justify-content-center mt-5">
    {{ knp_pagination_render(brands) }}
</div>
{% endblock %}
