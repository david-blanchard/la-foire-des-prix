{% extends 'layouts/admin.html.twig' %}

{% block children %}
<div class="container">
    <h2 class="text-center my-5">
        Marques
        <a href="{{ path('admin_brands_create') }}" class="btn btn-outline-primary" alt="Créer" title="Créer">
            <i class="fa fa-edit" aria-hidden="true"></i>
        </a>
    </h2>
    <table class="table table-striped table-sm table-hover">
        <thead class="thead-dark">
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Nom</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
        {% for item in brands %}
            <tr>            knp_paginator:
                page_range: 5
                default_options:
                    page_name: page
                    sort_field_name: sort
                    sort_direction_name: direction
                    distinct: true
                template:
                    pagination: '@KnpPaginator/Pagination/bootstrap_v4_pagination.html.twig'
                <th>
                    <a href="javascript:void(0)" class="btn btn-outline-warning" alt="Editer {{ item.id }}" title="Editer {{ item.id }}">
                        <i class="fa fa-edit" aria-hidden="true"></i>
                    </a>
                </th>
                <td>{{ item.name }}</td>
                <td>
                    <a href="javascript:void(0)" class="btn btn-outline-danger" alt="Supprimer" title="Supprimer">
                        <i class="fa fa-trash" aria-hidden="true"></i>
                    </a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
<div class="d-flex justify-content-center mt-5">
    {{ knp_pagination_render(brands) }}
</div>
{% endblock %}
