{% extends 'layouts/admin.html.twig' %}

{% block children %}
<div class="container">
    <h2 class="text-center my-5">
        Associez une image au produit sélectionné
    </h2>
    <table class="table table-striped table-sm">
        <thead class="thead-dark">
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Nom</th>
                <th scope="col">
                    Marque
                </th>
                <th scope="col">
                    Images
                </th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <th>
                    <span class="btn btn-outline-warning">
                        {{ product.id }}
                    </span>
                </th>
                <td>{{ product.name }}</td>
                <td>{{ brand.name }}</td>
                <td>
                    {% set size = 50 %}
                    {% for image in assocImages %}
                        {{ include('product_info/image.html.twig') }}
                    {% endfor %}
                </td>
            </tr>
            <tr>
                <td colspan="4">
                    <form method="POST" action="{{ path('admin_product_images_create', { 'id': product.id } ) }}">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('product_images') }}">
                        <input type="hidden" name="product" value="{{ product.id }}" />
                        <div class="col-12">
                            <div class="form-group">
                                <label>Image</label>
                                <select name="image" class="form-control">
                                    {% for image in images %}
                                        <option value="{{ image.id }}">
                                            {{ image.alt }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex justify-content-center mb-5">
                                <button type="submit" class="btn btn-outline-primary">Valider</button>
                            </div>
                        </div>
                    </form>
                </td>
            </tr>
        </tbody>
    </table>
</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/product-page.js') }}"></script>
{% endblock %}
