{% extends 'layouts/admin.html.twig' %}

{% block title %}
    Association Campagne/Produit
{% endblock %}

{% block children %}

<div class="container">
    <h2 class="text-center my-5">
        Ajouter un produit à une campagne
    </h2>
    <table class="table table-striped table-sm">
        <thead class="thead-dark">
        <tr>
            <th scope="col">ID</th>
            <th scope="col">Nom</th>
        </tr>
        </thead>
        <tbody>
        {% for item in campaign %}
            <tr>
                <th>
                    <a href="{{ path('admin_campaign_product_new', { id: item.id }) }}" class="btn btn-outline-warning" alt="Editer {{ item.id }}" title="Editer {{ item.id }}">
                        <i class="fa fa-edit" aria-hidden="true"></i>
                    </a>
                </th>
                <td>{{ item.name }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    <div class="d-flex justify-content-center mt-5">
        {{ knp_pagination_render(products) }}
    </div>
    <a href="{{ path('admin_campaign_product_index') }}">back to list</a>
</div>


{% endblock %}
