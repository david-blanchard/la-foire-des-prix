{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "api-platform/doctrine-orm": "^4.1.20",
        "api-platform/symfony": "^4.1.20",
        "cocur/slugify": "^4.6",
        "doctrine/dbal": "^3.10.1",
        "doctrine/doctrine-bundle": "^2.15.1",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.5.2",
        "gesdinet/jwt-refresh-token-bundle": "^1.5",
        "guzzlehttp/guzzle": "^7.9.3",
        "knplabs/knp-paginator-bundle": "^6.9.1",
        "lexik/jwt-authentication-bundle": "^3.1.1",
        "nelmio/api-doc-bundle": "^5.5",
        "nelmio/cors-bundle": "^2.5",
        "pentatrion/vite-bundle": "^8.2.0",
        "phpdocumentor/reflection-docblock": "^5.6.2",
        "phpstan/phpdoc-parser": "^2.2",
        "stof/doctrine-extensions-bundle": "^1.14",
        "symfony/asset": "7.3.*",
        "symfony/cache": "7.3.*",
        "symfony/config": "7.3.*",
        "symfony/console": "7.3.*",
        "symfony/dependency-injection": "7.3.*",
        "symfony/doctrine-messenger": "7.3.*",
        "symfony/dotenv": "7.3.*",
        "symfony/event-dispatcher": "7.3.*",
        "symfony/expression-language": "7.3.*",
        "symfony/finder": "7.3.*",
        "symfony/flex": "^2.8.1",
        "symfony/form": "7.3.*",
        "symfony/framework-bundle": "7.3.*",
        "symfony/http-foundation": "7.3.*",
        "symfony/http-kernel": "7.3.*",
        "symfony/mailer": "7.3.*",
        "symfony/messenger": "7.3.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/notifier": "7.3.*",
        "symfony/property-access": "7.3.*",
        "symfony/property-info": "7.3.*",
        "symfony/routing": "7.3.*",
        "symfony/runtime": "7.3.*",
        "symfony/security-bundle": "7.3.*",
        "symfony/serializer": "7.3.*",
        "symfony/translation": "7.3.*",
        "symfony/twig-bundle": "7.3.*",
        "symfony/validator": "7.3.*",
        "symfony/yaml": "7.3.*",
        "symfonycasts/tailwind-bundle": "^0.10.1",
        "symfonycasts/verify-email-bundle": "^1.17.3",
        "twig/extra-bundle": "^2.12|^3.21",
        "twig/twig": "^2.12|^3.21.1"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.1",
        "fakerphp/faker": "^1.24.1",
        "friendsofphp/php-cs-fixer": "^3.86",
        "kenaths/phpstan-fixer": "^1.71",
        "phpstan/phpstan": "1.11.7",
        "phpunit/phpunit": "^12.3.4",
        "squizlabs/php_codesniffer": "^3.13.2",
        "symfony/browser-kit": "7.3.*",
        "symfony/css-selector": "7.3.*",
        "symfony/debug-bundle": "^7.3",
        "symfony/maker-bundle": "^1.64.0",
        "symfony/phpunit-bridge": "^7.3.1",
        "symfony/stopwatch": "7.3.*",
        "symfony/var-dumper": "^7.3",
        "symfony/web-profiler-bundle": "7.3.*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "export:postman": [
            "curl http://localhost:8081/api/docs.jsonopenapi -o openapi/resource.json",
            "openapi2postmanv2 -s openapi/resource.json -o openapi/postman_collection.json -p"
        ],
        "test": "bin/phpunit 1> var/log/testdox.log; tail -n 1 ./var/log/testdox.log >> ./var/log/testdox.txt; cat ./var/log/testdox.txt",
        "refresh": "bin/console doctrine:database:drop --force && php bin/console doctrine:database:create && php bin/console doctrine:migrations:migrate --no-interaction && php bin/console doctrine:fixtures:load --no-interaction",
        "refresh-test": "bin/console doctrine:database:drop --force --env=test && php bin/console doctrine:database:create --env=test && php bin/console doctrine:migrations:migrate --no-interaction --env=test && php bin/console doctrine:fixtures:load --no-interaction --env=test",
        "cover": "composer inspect && composer beautify && composer analyse",
        "beautify": "vendor/bin/phpcbf ./src",
        "lint": "vendor/bin/phpcs",
        "lint:fix": "vendor/bin/php-cs-fixer fix ./src && vendor/bin/php-cs-fixer fix ./src",
        "analyse": "vendor/bin/phpstan analyse",
        "analyse:fix": "composer lint:fix && vendor/bin/phpstan-fix ./src --level=8",
        "publish": "bin/console assets:install public --symlink",
        "retest": "composer refresh-test && composer test"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.3.*"
        }
    }
}
