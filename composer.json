{
    "type": "project",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "cocur/slugify": "^4.6",
        "doctrine/dbal": "^3.9.4",
        "doctrine/doctrine-bundle": "^2.14",
        "doctrine/doctrine-migrations-bundle": "^3.4.2",
        "doctrine/orm": "^3.3.3",
        "guzzlehttp/guzzle": "^7.9.3",
        "knplabs/knp-paginator-bundle": "^6.8",
        "pentatrion/vite-bundle": "^8.1.0",
        "stof/doctrine-extensions-bundle": "^1.14",
        "symfony/asset": "7.2.*",
        "symfony/config": "7.2.*",
        "symfony/console": "7.2.*",
        "symfony/dependency-injection": "7.2.*",
        "symfony/doctrine-messenger": "7.2.*",
        "symfony/dotenv": "7.2.*",
        "symfony/event-dispatcher": "7.2.*",
        "symfony/finder": "7.2.*",
        "symfony/flex": "^2.5.1",
        "symfony/form": "7.2.*",
        "symfony/framework-bundle": "7.2.*",
        "symfony/http-foundation": "7.2.*",
        "symfony/http-kernel": "7.2.*",
        "symfony/mailer": "7.2.*",
        "symfony/messenger": "7.2.*",
        "symfony/monolog-bundle": "^3.10",
        "symfony/notifier": "7.2.*",
        "symfony/routing": "7.2.*",
        "symfony/runtime": "7.2.*",
        "symfony/security-bundle": "7.2.*",
        "symfony/translation": "7.2.*",
        "symfony/twig-bundle": "7.2.*",
        "symfony/validator": "7.2.*",
        "symfony/yaml": "7.2.*",
        "symfonycasts/tailwind-bundle": "^0.10.0",
        "symfonycasts/verify-email-bundle": "^1.17.3",
        "twig/extra-bundle": "^2.12|^3.21",
        "twig/twig": "^2.12|^3.21.1"
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.1",
        "fakerphp/faker": "^1.24.1",
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "1.11.7",
        "phpunit/phpunit": "^12.1.5",
        "squizlabs/php_codesniffer": "^3.13",
        "symfony/browser-kit": "7.2.*",
        "symfony/css-selector": "7.2.*",
        "symfony/debug-bundle": "^7.2",
        "symfony/maker-bundle": "^1.63.0",
        "symfony/phpunit-bridge": "^7.2.6",
        "symfony/stopwatch": "7.2.*",
        "symfony/var-dumper": "^7.2.6",
        "symfony/web-profiler-bundle": "7.2.*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test": "php bin/phpunit 1> var/log/testdox.log; tail -n 1 ./var/log/testdox.log >> ./var/log/testdox.txt; cat ./var/log/testdox.txt",
        "refresh": "php bin/console doctrine:database:drop --force && php bin/console doctrine:database:create && php bin/console doctrine:migrations:migrate --no-interaction && php bin/console doctrine:fixtures:load --no-interaction",
        "refresh-test": "php bin/console doctrine:database:drop --force --env=test && php bin/console doctrine:database:create --env=test && php bin/console doctrine:migrations:migrate --no-interaction --env=test && php bin/console doctrine:fixtures:load --no-interaction --env=test",
        "cover": "composer inspect && composer beautify && composer analyse",
        "analyse": "vendor/bin/phpstan analyse",
        "inspect": "vendor/bin/phpcs",
        "beautify": "vendor/bin/phpcbf ./src",
        "fix": "vendor/bin/php-cs-fixer fix ./src",
        "retest": "composer refresh-test && composer test"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    }
}
